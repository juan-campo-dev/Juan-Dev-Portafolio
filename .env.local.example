# Variables de entorno locales (frontend Next.js)
# Copia este archivo a .env.local y rellena con tus valores reales.
# NUNCA commitees .env.local con secretos reales.

# URL base de la API Laravel (sin slash final)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Clave de Gemini (solo si se usa chatbot/IA en frontend; preferir backend)
GEMINI_API_KEY=your_gemini_api_key_here
